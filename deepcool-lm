def get_temp_color(temp):
    """Return color gradient based on temperature"""
    if temp < 40:
        return (100, 200, 255)  # Cool blue
    elif temp < 60:
        return (100, 255, 100)  # Green
    elif temp < 75:
        return (255, 220, 50)   # Yellow
    elif temp < 85:
        return (255, 140, 0)    # Orange
    else:
        return (255, 50, 50)    # Red

def get_load_color(pct):
    """Return a solid color for a load percentage (core squares + utilization %).

    Idle reads as a dim green, rising through bright green, yellow and orange to
    red as the load climbs.
    """
    if pct < 12:
        return (55, 150, 70)    # idle - dim green
    elif pct < 35:
        return (90, 220, 95)    # light load - bright green
    elif pct < 60:
        return (230, 210, 55)   # yellow
    elif pct < 82:
        return (240, 150, 45)   # orange
    else:
        return (240, 70, 60)    # red

def get_vram_color(frac):
    """Return a color for a VRAM fill fraction (0.0-1.0)."""
    if frac < 0.60:
        return (90, 200, 120)   # green
    elif frac < 0.80:
        return (230, 210, 60)   # yellow
    elif frac < 0.92:
        return (240, 150, 45)   # orange
    else:
        return (240, 70, 60)    # red

def _find_font_file(bold=False):
    """Locate a DejaVu Sans font file across common distro layouts.

    The path differs by distro (Arch uses .../fonts/TTF, Debian/Ubuntu use
    .../fonts/truetype/dejavu), so try the known locations and fall back to
    fc-match. Returns a path string, or None if nothing is found.
    """
    suffix = "-Bold" if bold else ""
    candidates = [
        f"/usr/share/fonts/TTF/DejaVuSans{suffix}.ttf",
        f"/usr/share/fonts/truetype/dejavu/DejaVuSans{suffix}.ttf",
        f"/usr/share/fonts/dejavu/DejaVuSans{suffix}.ttf",
        f"/usr/local/share/fonts/DejaVuSans{suffix}.ttf",
    ]
    for path in candidates:
        if os.path.exists(path):
            return path
    try:
        pattern = "DejaVu Sans:bold" if bold else "DejaVu Sans"
        out = subprocess.run(['fc-match', '-f', '%{file}', pattern],
                             capture_output=True, text=True, timeout=2)
        path = out.stdout.strip()
        if out.returncode == 0 and path and os.path.exists(path):
            return path
    except (OSError, subprocess.SubprocessError):
        pass
    return None

# Font sizes encode the priority: temperature is largest, then utilization,
# then the smaller supporting readouts (frequency / VRAM text / labels).
FONT_SIZES = {'temp': 46, 'util': 30, 'label': 22, 'small': 19}

def load_fonts():
    """Load fonts with a robust path search and a graceful fallback."""
    bold = _find_font_file(bold=True)
    regular = _find_font_file(bold=False)
    try:
        if bold and regular:
            return {
                'temp':  ImageFont.truetype(bold, FONT_SIZES['temp']),
                'util':  ImageFont.truetype(bold, FONT_SIZES['util']),
                'label': ImageFont.truetype(bold, FONT_SIZES['label']),
                'small': ImageFont.truetype(regular, FONT_SIZES['small']),
            }
    except OSError:
        pass
    default = ImageFont.load_default()
    return {k: default for k in FONT_SIZES}

# NVML (pynvml) state: None = not yet tried, False = unavailable, list = handles.
# Initialised once and reused so per-frame queries don't spawn a subprocess.
_nvml_state = None

def _nvml_handles():
    """Return cached NVML device handles, initialising NVML at most once.

    Returns a non-empty list of handles, or None if pynvml/NVML is unavailable
    (the caller then falls back to nvidia-smi).
    """
    global _nvml_state
    if _nvml_state is None:
        try:
            import pynvml
            pynvml.nvmlInit()
            _nvml_state = [pynvml.nvmlDeviceGetHandleByIndex(i)
                           for i in range(pynvml.nvmlDeviceGetCount())]
        except Exception:
            _nvml_state = False
    return _nvml_state or None

def _read_nvidia_nvml():
    """Read NVIDIA GPU stats via NVML (persistent handle, ~microseconds).

    Returns a dict {temp, util, mem_used, mem_total} (memory in MiB) for the
    hottest GPU, or None if NVML is unavailable or errors.
    """
    handles = _nvml_handles()
    if not handles:
        return None
    try:
        import pynvml
        rows = []
        for h in handles:
            temp = pynvml.nvmlDeviceGetTemperature(h, pynvml.NVML_TEMPERATURE_GPU)
            util = pynvml.nvmlDeviceGetUtilizationRates(h).gpu
            mem = pynvml.nvmlDeviceGetMemoryInfo(h)
            rows.append((float(temp), float(util),
                         mem.used / (1024 * 1024), mem.total / (1024 * 1024)))
        if rows:
            temp, util, used, total = max(rows, key=lambda r: r[0])
            return {'temp': temp, 'util': util, 'mem_used': used, 'mem_total': total}
    except Exception:
        pass
    return None

def _read_nvidia_smi():
    """Read NVIDIA GPU stats by spawning nvidia-smi (fallback when NVML is
    unavailable). Returns the same dict shape as _read_nvidia_nvml(), or None."""
    try:
        out = subprocess.run(
            ['nvidia-smi',
             '--query-gpu=temperature.gpu,utilization.gpu,memory.used,memory.total',
             '--format=csv,noheader,nounits'],
            capture_output=True, text=True, timeout=2,
        )
        if out.returncode == 0:
            rows = []
            for line in out.stdout.splitlines():
                parts = [p.strip() for p in line.split(',')]
                if len(parts) >= 4:
                    try:
                        rows.append(tuple(float(x) for x in parts[:4]))
                    except ValueError:
                        continue
            if rows:
                temp, util, used, total = max(rows, key=lambda r: r[0])
                return {'temp': temp, 'util': util, 'mem_used': used, 'mem_total': total}
    except (OSError, subprocess.SubprocessError):
        pass
    return None

def read_nvidia_gpu():
    """Read discrete NVIDIA GPU stats (temp, util, VRAM in MiB) for the hottest
    GPU, or None if no NVIDIA GPU is accessible.

    NVIDIA GPUs are invisible to psutil.sensors_temperatures()/lm-sensors. Prefer
    NVML via pynvml (a persistent handle queried in microseconds, no per-frame
    subprocess), falling back to spawning nvidia-smi when the binding is absent.
    """
    return _read_nvidia_nvml() or _read_nvidia_smi()

_core_ids_cache = None

def read_core_ids():
    """Map each logical CPU to its physical core_id via sysfs topology.

    Used to fold SMT sibling threads back onto physical cores. The topology is
    fixed for the life of the process, so the result is read once and cached.
    Returns a list indexed by logical CPU, or an empty list if unavailable.
    """
    global _core_ids_cache
    if _core_ids_cache is not None:
        return _core_ids_cache
    ids = []
    i = 0
    while True:
        try:
            with open(f"/sys/devices/system/cpu/cpu{i}/topology/core_id") as f:
                ids.append(int(f.read().strip()))
        except OSError:
            break
        i += 1
    _core_ids_cache = ids
    return ids

def fold_cores(per_cpu):
    """Fold per-logical-CPU usage onto physical cores, taking the busier sibling.

    Falls back to the raw per-logical list if topology can't be read or doesn't
    line up. Returns a list of usages ordered by physical core_id.
    """
    core_ids = read_core_ids()
    if not core_ids or len(core_ids) != len(per_cpu):
        return list(per_cpu)
    groups = {}
    for usage, cid in zip(per_cpu, core_ids):
        groups[cid] = max(groups.get(cid, 0.0), usage)
    return [groups[cid] for cid in sorted(groups)]

def read_psutil_gpu_temp(temps):
    """Read AMD/nouveau GPU temperature from psutil sensor data.

    Returns a float, or None if no matching sensor is present.
    """
    for key in ('amdgpu', 'nouveau'):
        if key in temps and temps[key]:
            edge = next((s.current for s in temps[key] if s.label == 'edge'), None)
            return edge if edge is not None else temps[key][0].current
    return None

def read_cpu_freq_ghz():
    """Return the fastest active core clock in GHz.

    psutil.cpu_freq().current is the arithmetic mean across all logical CPUs.
    On a GPU-bound / mostly-idle workload most cores park at their minimum
    (~0.6 GHz under amd-pstate 'powersave'), dragging that mean far below the
    boost clock the busy cores are actually running at. Windows Task Manager and
    the stock DeepCool software report the peak active-core clock, so match that
    by taking the max across cores. Returns a float GHz, or 0.0 if unavailable.
    """
    try:
        per = psutil.cpu_freq(percpu=True)
        if per:
            return round(max(c.current for c in per) / 1000, 2)
        freq = psutil.cpu_freq()
        if freq:
            return round(freq.current / 1000, 2)
    except Exception:
        pass
    return 0.0

def get_system_info():
    """Get all system information"""
    info = {
        'cpu_temp': 0.0,
        'gpu_temp': 0.0,
        'cpu_percent': 0.0,
        'cpu_freq': 0.0,
        'cpu_cores': [],      # per physical core usage %
        'gpu_util': 0.0,      # GPU utilization %
        'vram_used': 0.0,     # MiB
        'vram_total': 0.0,    # MiB
    }

    # CPU temperature
    try:
        temps = psutil.sensors_temperatures()
        # CPU: try AMD then Intel then generic
        for key in ('k10temp', 'coretemp', 'cpu_thermal', 'zenpower'):
            if key in temps and temps[key]:
                pref = next((s.current for s in temps[key] if s.label in ('Tctl', 'Package id 0', 'Tdie')), None)
                info['cpu_temp'] = round(pref if pref is not None else temps[key][0].current, 1)
                break
        # GPU: prefer discrete NVIDIA (invisible to psutil, read via nvidia-smi),
        # then fall back to AMD/nouveau temp only. This avoids showing an idle
        # integrated GPU (e.g. Ryzen amdgpu sensor) instead of the busy card.
        nv = read_nvidia_gpu()
        if nv is not None:
            info['gpu_temp'] = round(nv['temp'], 1)
            info['gpu_util'] = round(nv['util'], 1)
            info['vram_used'] = nv['mem_used']
            info['vram_total'] = nv['mem_total']
        else:
            gpu_temp = read_psutil_gpu_temp(temps)
            if gpu_temp is not None:
                info['gpu_temp'] = round(gpu_temp, 1)
    except:
        pass

    # CPU usage (overall + per physical core) and frequency
    try:
        per_cpu = psutil.cpu_percent(interval=0.1, percpu=True)
        if per_cpu:
            info['cpu_percent'] = round(sum(per_cpu) / len(per_cpu), 1)
            info['cpu_cores'] = fold_cores(per_cpu)
        info['cpu_freq'] = read_cpu_freq_ghz()
    except:
        pass

    return info

def rgb_to_framebuffer(img):
    """Convert PIL RGB image to RGB565 framebuffer"""
    if img.mode != 'RGB':
        img = img.convert('RGB')
    if img.size != (WIDTH, HEIGHT):
        img = img.resize((WIDTH, HEIGHT), Image.Resampling.LANCZOS)

    framebuffer = bytearray()
    pixels = img.load()

    for y in range(HEIGHT):
        for x in range(WIDTH):
            r, g, b = pixels[x, y]
            # Convert to RGB565
            r5 = (r >> 3) & 0x1F
            g6 = (g >> 2) & 0x3F
            b5 = (b >> 3) & 0x1F
            rgb565 = (r5 << 11) | (g6 << 5) | b5
            # Append as little-endian
            framebuffer.append(rgb565 & 0xFF)
            framebuffer.append((rgb565 >> 8) & 0xFF)

    return bytes(framebuffer)

def draw_rounded_rect(draw, xy, radius, fill=None, outline=None, width=1):
    """Draw a rounded rectangle using PIL's built-in method"""
    draw.rounded_rectangle(xy, radius=radius, fill=fill, outline=outline, width=width)

def render_monitor_display(info, fonts):
    """System monitor layout for the 320x240 panel.

    Top edge:   one square per physical CPU core, colour-coded by load.
    CPU section (taller): label + large colour-coded temperature on the left,
                utilisation (colour-coded) and frequency on the right.
    GPU section: label + large colour-coded temperature, utilisation on the right.
    Bottom edge: VRAM usage bar, colour-coded by fill.

    Font sizes carry the priority the user asked for: temperature largest, then
    utilisation, then the smaller supporting readouts.
    """
    BG      = (14, 14, 18)
    BORDER  = (40, 40, 50)
    LABEL   = (120, 120, 140)
    SUBTLE  = (140, 140, 160)
    TRACK   = (30, 30, 38)
    LABEL_CX = 150        # x-centre of the middle label column
    RIGHT_X  = 300        # right edge of the right-hand readout column

    img = Image.new('RGB', (WIDTH, HEIGHT), color=BG)
    draw = ImageDraw.Draw(img)

    def blit(text, font, fill, cy, left=None, right=None, cx=None):
        """Draw text with its ink vertically centred on cy, horizontally
        anchored by exactly one of left / right / cx (centre)."""
        l, t, r, b = draw.textbbox((0, 0), text, font=font)
        w, h = r - l, b - t
        y = cy - h / 2 - t
        if left is not None:
            x = left - l
        elif right is not None:
            x = right - (l + w)
        else:
            x = cx - w / 2 - l
        draw.text((x, y), text, font=font, fill=fill)

    def draw_section(box, label, temp, util_text, util_fill, sub_text):
        """One CPU/GPU section: large temp (left, vertically centred), label
        (centre column), utilisation + secondary readout (right column)."""
        draw_rounded_rect(draw, box, radius=8, outline=BORDER, width=2)
        cy = (box[1] + box[3]) / 2
        blit(f"{temp:.0f}°", fonts['temp'], get_temp_color(temp), cy, left=20)
        blit(label, fonts['label'], LABEL, cy, cx=LABEL_CX)
        blit(util_text, fonts['util'], util_fill, cy - 16, right=RIGHT_X)
        blit(sub_text, fonts['small'], SUBTLE, cy + 18, right=RIGHT_X)

    # === TOP: one square per physical core, colour-coded by load ===
    cores = info.get('cpu_cores') or []
    if cores:
        strip_x0, strip_x1 = 12, WIDTH - 12
        strip_y0, strip_h = 8, 18
        cell_w = (strip_x1 - strip_x0) / len(cores)
        sq = cell_w - 2  # 2px separator between squares
        for i, pct in enumerate(cores):
            x0 = strip_x0 + i * cell_w
            draw.rectangle([x0, strip_y0, x0 + sq, strip_y0 + strip_h], fill=(0, 0, 0))
            draw.rectangle([x0 + 1, strip_y0 + 1, x0 + sq - 1, strip_y0 + strip_h - 1],
                           fill=get_load_color(pct))

    # === CPU SECTION (taller) ===
    draw_section([12, 34, 308, 122], "CPU", info['cpu_temp'],
                 f"{info['cpu_percent']:.0f}%", get_load_color(info['cpu_percent']),
                 f"{info['cpu_freq']:.2f} GHz")

    # === GPU SECTION (VRAM value shown below utilisation) ===
    total = info.get('vram_total') or 0
    vram_text = (f"{info['vram_used'] / 1024:.0f} / {total / 1024:.0f} GB"
                 if total > 0 else "n/a")
    draw_section([12, 130, 308, 212], "GPU", info['gpu_temp'],
                 f"{info['gpu_util']:.0f}%", get_load_color(info['gpu_util']),
                 vram_text)

    # === BOTTOM: clean VRAM usage bar (colour-coded, no text) ===
    bar_x, bar_y, bar_w, bar_h = 16, 216, WIDTH - 32, 18
    radius = bar_h // 2
    draw_rounded_rect(draw, [bar_x, bar_y, bar_x + bar_w, bar_y + bar_h],
                      radius=radius, fill=TRACK)
    if total > 0:
        frac = max(0.0, min(info['vram_used'] / total, 1.0))
        fill_w = int(bar_w * frac)
        if fill_w >= radius * 2:
            draw_rounded_rect(draw, [bar_x, bar_y, bar_x + fill_w, bar_y + bar_h],
                              radius=radius, fill=get_vram_color(frac))

    return rgb_to_framebuffer(img)

